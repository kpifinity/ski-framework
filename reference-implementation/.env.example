# SKI Framework Reference Implementation Configuration

# ============================================================================
# ANTHROPIC API (Required)
# ============================================================================
ANTHROPIC_API_KEY=sk-your-api-key-here

# ============================================================================
# MILM INFERENCE ENGINE
# ============================================================================
MILM_MODEL=claude-opus-4-6
MILM_TEMPERATURE=0
MILM_MAX_TOKENS=500
MILM_LOG_LEVEL=INFO

# ============================================================================
# DATA INTEGRATION (SIDECAR)
# ============================================================================
# Source for operational telemetry: kafka, http, or file
TELEMETRY_SOURCE=kafka
TELEMETRY_BATCH_SIZE=100
HEARTBEAT_INTERVAL=60

# Kafka configuration (if TELEMETRY_SOURCE=kafka)
KAFKA_BROKERS=kafka:9092
KAFKA_TOPIC=operational-data

# ============================================================================
# AUDIT LEDGER (PostgreSQL)
# ============================================================================
POSTGRES_DB=ski_ledger
POSTGRES_USER=ski
POSTGRES_PASSWORD=ski_password

# ============================================================================
# MONITORING & OBSERVABILITY
# ============================================================================
LOG_LEVEL=INFO

# Grafana credentials
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin

# pgAdmin credentials
PGADMIN_EMAIL=admin@example.com
PGADMIN_PASSWORD=admin

# ============================================================================
# OPTIONAL: DEPLOYMENT PARAMETERS
# ============================================================================
# Deployment name (used in container names, logging, etc.)
DEPLOYMENT_NAME=ski-reference-implementation

# Sector for Knowledge Graph (energy, finance, manufacturing, defense)
SECTOR=energy

# Knowledge Graph version to load
KG_VERSION=v1.0

# ============================================================================
# OPTIONAL: ADVANCED CONFIGURATION
# ============================================================================
# Enable/disable services
ENABLE_SIDECAR=true
ENABLE_PROMETHEUS=true
ENABLE_GRAFANA=true
ENABLE_PGADMIN=true

# Database backup settings
BACKUP_ENABLED=true
BACKUP_INTERVAL_DAYS=7

# Security
TLS_ENABLED=false
API_KEY_REQUIRED=false

# Resource limits
MILM_WORKERS=4
POSTGRES_SHARED_BUFFERS=256MB
POSTGRES_MAX_CONNECTIONS=100
