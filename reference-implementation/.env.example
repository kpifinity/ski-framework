# ============================================================================
# SKI Framework Reference Implementation — Configuration
# ============================================================================
# Copy this file to .env and fill in the REQUIRED values. The stack will
# refuse to start if any required variable is missing or set to the default
# placeholder "CHANGE_ME". Use scripts/setup.sh to generate strong secrets
# automatically.
# ============================================================================

# ----------------------------------------------------------------------------
# INFERENCE BACKEND (REQUIRED)
# ----------------------------------------------------------------------------
# "ollama"     — Local LLM runtime. Default. Conformant with Pillar S (Sovereignty).
# "vllm"       — Local LLM runtime (alternative). Conformant.
# "llama_cpp"  — Local LLM runtime (alternative). Conformant.
# "anthropic"  — Cloud API call to Anthropic. NON-CONFORMANT DEMO MODE ONLY.
#                Disqualifies the deployment from all SKI conformance levels.
#                Do NOT use in production or with real regulated data.
SKI_INFERENCE_BACKEND=ollama

# Model name. For Ollama, must be a model you've already pulled.
# Recommended starter models (small, open-weights, instruction-tuned):
#   qwen2.5:7b-instruct, mistral:7b-instruct, phi3.5:3.8b-mini-instruct
SKI_MODEL_NAME=qwen2.5:7b-instruct

# SHA-256 of the model file used at evaluation time. Set after pulling the
# model. The SKI Model service refuses to start if this does not match the
# pulled artifact (Determinism Enforcement Control B3.4).
SKI_MODEL_FILE_SHA256=

# Deterministic decoding parameters. Do not change unless you understand the
# determinism implications and have updated the conformance test suite.
SKI_MODEL_SEED=42
SKI_MODEL_MAX_TOKENS=512

# Determinism canary interval (seconds). The service periodically re-runs a
# fixed canary input and verifies the verdict is unchanged.
DETERMINISM_CANARY_INTERVAL=300

# ----------------------------------------------------------------------------
# SKI API AUTHENTICATION (REQUIRED)
# ----------------------------------------------------------------------------
# Generate with:  openssl rand -hex 32
SKI_API_KEY=CHANGE_ME

# ----------------------------------------------------------------------------
# KNOWLEDGE GRAPH (REQUIRED for runtime)
# ----------------------------------------------------------------------------
KG_PATH=/app/kg/kg.json
# The SKI Model refuses to load an unsigned KG by default. Setting this to
# false is permitted only for local demos and disqualifies the deployment
# from all conformance levels.
KG_REQUIRE_SIGNATURE=true

# ----------------------------------------------------------------------------
# AUDIT LEDGER (PostgreSQL) (REQUIRED)
# ----------------------------------------------------------------------------
# Generate strong values via setup.sh. Defaults are intentionally absent.
POSTGRES_DB=ski_ledger
POSTGRES_USER=CHANGE_ME
POSTGRES_PASSWORD=CHANGE_ME

# ----------------------------------------------------------------------------
# DATA INTEGRATION (SIDECAR)
# ----------------------------------------------------------------------------
# Source for operational telemetry: file (default), http, or kafka
TELEMETRY_SOURCE=file
TELEMETRY_BATCH_SIZE=100
HEARTBEAT_INTERVAL=60

# Kafka — only used when TELEMETRY_SOURCE=kafka. Enable with:
#   docker compose --profile kafka up -d
KAFKA_BROKERS=kafka:9092
KAFKA_TOPIC=operational-data

# ----------------------------------------------------------------------------
# MONITORING (REQUIRED for Grafana)
# ----------------------------------------------------------------------------
LOG_LEVEL=INFO
GRAFANA_USER=CHANGE_ME
GRAFANA_PASSWORD=CHANGE_ME
GRAFANA_PROTOCOL=https

# pgAdmin — only used with `--profile pgadmin`. Not recommended outside dev.
PGADMIN_EMAIL=
PGADMIN_PASSWORD=

# ----------------------------------------------------------------------------
# DEPLOYMENT METADATA
# ----------------------------------------------------------------------------
DEPLOYMENT_NAME=ski-reference-implementation
SECTOR=demo
KG_VERSION=v0.1

# ----------------------------------------------------------------------------
# SECURITY
# ----------------------------------------------------------------------------
# TLS is enabled by default. Self-signed certificates are generated by
# scripts/setup.sh. For production, replace tls/ with certs from your own CA.
TLS_ENABLED=true
API_KEY_REQUIRED=true

# ----------------------------------------------------------------------------
# SERVICE TOGGLES (advanced)
# ----------------------------------------------------------------------------
ENABLE_SIDECAR=true
ENABLE_PROMETHEUS=true
ENABLE_GRAFANA=true

# Resource limits
SKI_MODEL_WORKERS=1   # MUST be 1 — see docs/CONCURRENCY.md
POSTGRES_SHARED_BUFFERS=256MB
POSTGRES_MAX_CONNECTIONS=100
