# Force LF line endings for all source files so Windows + git autocrlf
# doesn't rewrite them on every `git add`. This eliminates the
# constant editor-snapshot-vs-disk mismatch that triggers Cowork's
# "modified externally" reminders.

* text=auto eol=lf

# Python, YAML, TOML, JSON, Markdown, SQL, shell, Dockerfiles
*.py     text eol=lf
*.pyi    text eol=lf
*.yml    text eol=lf
*.yaml   text eol=lf
*.toml   text eol=lf
*.json   text eol=lf
*.md     text eol=lf
*.sql    text eol=lf
*.sh     text eol=lf
*.cfg    text eol=lf
*.ini    text eol=lf
Dockerfile* text eol=lf

# Binary files - never normalize
*.png    binary
*.jpg    binary
*.gif    binary
*.pdf    binary
*.whl    binary
*.gz     binary
*.zip    binary
